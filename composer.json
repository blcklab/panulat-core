{
    "name": "blcklab/panulat-core",
    "description": "Panulat Core: lightweight zero-runtime-dependency PHP 8.3+ framework library for JSON REST APIs.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "api",
        "json",
        "framework",
        "rest",
        "panulat"
    ],
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "ext-pdo": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Panulat\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Panulat\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs-fix": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
